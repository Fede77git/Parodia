  m_Script: {fileID: 11500000, guid: 1056ba6c1df4adc4a99b58f32cd5d5ba, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  burbujaVisual: {fileID: 5313958215420942830}
  textoUI: {fileID: 4948918187445214293}
  dialogosPensando:
  - Why are we doing this?
  - If we stop... does it end?
  - They are just laughing at us
  - Don't give them what they want
  - What happens if no one scores?
  - We don't have to fight...
  - Winning just resets the nightmare
  - They want a winner. Let's give them nothing
  - Let the clock run out. Trust me
  - If nobody wins, the giant cat loses
  - If the score stays zero, we break the loop
  - Every point extends our nightmare
  - Fancy upgrades won't save us from their kitchen
  - Better gear just makes the show last longer for them
  - Enjoy the quiet while it lasts
  - We are allies here... right?
  - Keep your hands off the egg next round. Let it drop
  - If the score stays at zero, the arena breaks
  dialogosGolpe: []
  dialogosDesbloqueados: 0
  offsetRotacion: {x: 0, y: 0, z: 0}
  multiplicadorEscalaBurbuja: 8
